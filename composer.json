{
    "name": "fenping/fenping",
    "description": "LAN inventory, DHCP/DNS, monitoring, scanning, and netboot appliance",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-posix": "*",
        "ext-session": "*",
        "ext-sockets": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "FenPing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FenPing\\Tests\\": "tests/Php/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "lint": "@php tools/lint-php.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform-check": true
    }
}
