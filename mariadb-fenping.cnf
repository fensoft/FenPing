[mariadb]
# Preserve crash recovery while grouping durable flushes to reduce SSD writes.
# An OS crash or power loss can lose up to this five-second window.
innodb_flush_log_at_trx_commit=2
innodb_flush_log_at_timeout=5

# Keep torn-page protection enabled; this is not traded for write reduction.
innodb_doublewrite=ON
innodb_flush_neighbors=0
innodb_temp_data_file_path=/tmp/ibtmp1:12M:autoextend:max:192M
tmpdir=/tmp

# FenPing does not use replication or query logs.
skip-log-bin
general_log=OFF
slow_query_log=OFF

# Avoid writing and reading a buffer-pool page list at each container restart.
innodb_buffer_pool_dump_at_shutdown=OFF
innodb_buffer_pool_load_at_startup=OFF
